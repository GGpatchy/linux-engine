NODE_ENV=development
PORT=3002
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_ticket_system?schema=public
DATABASE_SSL_MODE=disable
DATABASE_SSL_REJECT_UNAUTHORIZED=false
INBOUND_API_KEY=replace-with-your-own-secret-key
OUTBOUND_WEBHOOK_URL=
ADMIN_USERNAME=replace-with-a-non-default-admin-username
ADMIN_PASSWORD=replace-with-a-strong-password-at-least-12-characters
ADMIN_PASSWORD_HASH=
SESSION_SECRET=replace-with-a-long-random-session-secret
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Triverse Support
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
