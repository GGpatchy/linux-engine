<%- include("partials/head", { pageTitle }) %>

<main class="shell">
  <%- include("partials/brand-bar") %>
  <%- include("partials/page-utility-bar", { backHref: "/", backLabel: "Back", showProfileLink: true }) %>

  <section class="dashboard-header">
    <div>
      <span class="eyebrow">Admin Access Only</span>
      <h1>Employee Credentials</h1>
    </div>

    <div class="stats-card">
      <span>Email delivery</span>
      <strong><%= emailDeliveryConfigured ? "Ready" : "Setup" %></strong>
      <div class="stack-actions">
        <a class="button button-secondary" href="/">Open dashboard</a>
        <a class="button button-secondary" href="/raise-ticket">Raise ticket</a>
        <a class="button button-secondary" href="/admin/employees">Create employees</a>
        <form action="/logout" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="button button-ghost" type="submit">Logout</button>
        </form>
      </div>
    </div>
  </section>

  <section class="credential-layout">
    <div class="form-card">
      <span class="eyebrow">Provision Access</span>
      <h2>Create an employee</h2>

      <% if (success) { %>
        <div class="alert alert-success auto-dismiss-alert"><%= success %></div>
      <% } %>

      <% if (error) { %>
        <div class="alert alert-error auto-dismiss-alert"><%= error %></div>
      <% } %>

      <% if (!emailDeliveryConfigured) { %>
        <div class="alert alert-error">
          Brevo email delivery is not configured yet. Add sender and API or SMTP credentials before issuing employee access.
        </div>
      <% } %>

      <form action="/admin/employees" method="post" class="ticket-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <label>
          Employee name
          <input type="text" name="name" placeholder="Full name" required />
        </label>

        <label>
          Employee email
          <input type="email" name="email" placeholder="employee@example.com" required />
        </label>

        <label>
          Username
          <input type="text" name="username" placeholder="firstname.lastname" pattern="[A-Za-z0-9._-]{4,32}" required />
        </label>

        <button class="button" type="submit">Create Credentials</button>
      </form>
    </div>

    <div class="ticket-table-card">
      <div class="table-toolbar table-toolbar-rich">
        <div>
          <h2>Issued Credentials</h2>
          <p class="section-subtitle">This history shows which employees have credentials on file and whether the latest email delivery succeeded.</p>
        </div>
        <span class="table-count"><%= employees.length %> employees</span>
      </div>

      <div class="table-wrap">
        <table class="ticket-table credential-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Username</th>
              <th>Email</th>
              <th>Delivery</th>
              <th>Password Updated</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!employees.length) { %>
              <tr>
                <td colspan="6" class="empty-state">No employee credentials have been issued yet.</td>
              </tr>
            <% } %>

            <% employees.forEach(function(employee) { %>
              <tr>
                <td>
                  <strong><%= employee.name %></strong>
                </td>
                <td><code><%= employee.username %></code></td>
                <td><%= employee.email %></td>
                <td>
                  <span class="badge badge-delivery-<%= employee.credentialDeliveryStatus %>" data-delivery-badge>
                    <%= employee.credentialDeliveryStatus %>
                  </span>
                  <% if (employee.credentialDeliveryError) { %>
                    <small data-delivery-detail><%= employee.credentialDeliveryError %></small>
                  <% } else if (employee.lastCredentialSentAt) { %>
                    <small data-delivery-detail>Sent <%= new Date(employee.lastCredentialSentAt).toLocaleString() %></small>
                  <% } %>
                </td>
                <td data-password-updated-at>
                  <%= employee.passwordUpdatedAt ? new Date(employee.passwordUpdatedAt).toLocaleString() : "-" %>
                </td>
                <td>
                  <div class="employee-action-group">
                    <form action="/admin/employees/<%= employee.id %>/delete" method="post" onsubmit="return confirm('Delete <%= employee.username %>? This will remove the employee credential record.');">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <button
                        class="button button-danger button-inline button-icon-only"
                        type="submit"
                        aria-label="Delete <%= employee.username %>"
                        title="Delete employee"
                      >
                        <span class="button-icon-symbol" aria-hidden="true">
                          <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M3 6h18"></path>
                            <path d="M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2"></path>
                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                            <path d="M10 11v6"></path>
                            <path d="M14 11v6"></path>
                          </svg>
                        </span>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>

<script>
  window.setTimeout(() => {
    document.querySelectorAll(".auto-dismiss-alert").forEach((alert) => {
      alert.classList.add("alert-fade-out");
      window.setTimeout(() => alert.remove(), 320);
    });
  }, 4500);
</script>

<%- include("partials/footer") %>
